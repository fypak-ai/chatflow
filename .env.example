# ============================================================
# ChatFlow — variáveis de ambiente
# Copie para .env e preencha os valores
# ============================================================

# --- Database (local Docker) ---
DATABASE_URL=postgresql+asyncpg://chatflow:chatflow@postgres:5432/chatflow
REDIS_URL=redis://redis:6379

# --- Auth ---
SECRET_KEY=troque-isso-em-producao-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- AI (opcional, pelo menos um) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_AI_MODEL=gpt-4o

# --- GitHub Bot (opcional) ---
GITHUB_WEBHOOK_SECRET=

# --- CORS ---
# Em produção: URL do seu frontend Railway
FRONTEND_URL=http://localhost:3000

# ============================================================
# Railway — as variáveis abaixo são injetadas automaticamente
# Não precisa setar manualmente no Railway:
#   DATABASE_URL  (plugin Postgres)
#   REDIS_URL     (plugin Redis)
#   PORT          (Railway injeta)
# ============================================================
